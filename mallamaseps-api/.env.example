NODE_ENV=development
PORT=3100

# Mismas credenciales que siriscloud-auth
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Debe coincidir exactamente con JWT_ACCESS_SECRET en siriscloud-auth
JWT_ACCESS_SECRET=change-me-with-at-least-32-characters

# Job de alertas de consumo
USAGE_ALERTS_JOB_ENABLED=true
USAGE_ALERTS_JOB_INTERVAL_MS=600000

# Integraciones cross-service
AUTH_BASE_URL=http://localhost:3000
AUTH_INTERNAL_API_KEY=change-me-internal-key
INTEGRATIONS_BASE_URL=http://localhost:3010
INTEGRATIONS_API_KEY=change-me-integrations-key
BILLING_LIQUIDATION_NOTIFY_TO=admin@siriscloud.com.co
